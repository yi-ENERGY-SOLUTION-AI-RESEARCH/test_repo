# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 공공데이터포털 (나라장터) — Decoding 키
DATA_GO_KR_API_KEY=your-data-go-kr-service-key

# 한전 전력데이터개방포털 — 40자리 apiKey (bigdata.kepco.co.kr)
KEPCO_API_KEY=your-kepco-api-key
KEPCO_API_URL=https://bigdata.kepco.co.kr/openapi/v1/contract/electBidContInfo.do

# 이메일 (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# 카카오 Developers
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_REDIRECT_URI=http://localhost:8501

# Streamlit 앱 URL (배포 시 변경)
APP_BASE_URL=http://localhost:8501

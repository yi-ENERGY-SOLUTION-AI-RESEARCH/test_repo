# Streamlit Cloud secrets example — copy to .streamlit/secrets.toml

SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_ANON_KEY = "your-anon-key"

DATA_GO_KR_API_KEY = "your-data-go-kr-key"
KEPCO_API_KEY = "your-kepco-key"
KEPCO_API_URL = "https://bigdata.kepco.co.kr/openapi/v1/contract/electBidContInfo.do"

KAKAO_REST_API_KEY = "your-kakao-rest-api-key"
KAKAO_REDIRECT_URI = "https://your-app.streamlit.app"
APP_BASE_URL = "https://your-app.streamlit.app"
ALLOWED_EMAIL_DOMAIN = "yesyoungin.com"

SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "your@gmail.com"
SMTP_PASSWORD = "app-password"
SMTP_FROM = "your@gmail.com"
